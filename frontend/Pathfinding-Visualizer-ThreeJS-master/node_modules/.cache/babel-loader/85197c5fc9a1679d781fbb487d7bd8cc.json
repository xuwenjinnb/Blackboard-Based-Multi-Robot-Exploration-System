AAV,CAAb;AACAG,MAAAA,IAAI,CAACG,YAAL,GAAoB4C,IAAI,CAAC7B,KAAzB;AACAlB,MAAAA,IAAI,CAACE,MAAL,GAAce,wBAAwB,CAAC8B,IAAI,CAAC7B,KAAN,CAAtC;AACAlB,MAAAA,IAAI,CAACgD,UAAL,GAAkBD,IAAI,CAACC,UAAvB;AACAhD,MAAAA,IAAI,CAACiD,SAAL,GAAiBF,IAAI,CAACE,SAAtB;AACAjD,MAAAA,IAAI,CAACkD,SAAL,GAAiBH,IAAI,CAACG,SAAtB;AACA;AAjB2D;AAAA;AAAA;AAAA;AAAA;;AAmB5D,MAAMC,QAAQ,GAAG,CAACP,QAAQ,CAACO,QAAT,IAAqB,EAAtB,EAA0BN,GAA1B,CAA8B1B,YAA9B,CAAjB;AAEA,MAAMiC,SAAS,GAAG,CAACR,QAAQ,CAACQ,SAAT,IAAsB,EAAvB,EAChBP,GADgB,CACZb,aADY,EAEhBqB,MAFgB,CAET,UAACpB,QAAD;AAAA,WAAc,CAAC,MAAD,EAAS,UAAT,EAAqBqB,QAArB,CAA8BrB,QAAQ,CAAC/B,MAAvC,CAAd;AAAA,GAFS,CAAlB;AAIA,MAAMqD,cAAc,GAAG,EAAvB;;AAzB4D,8CA0BzCX,QAAQ,CAACY,eAAT,IAA4B,EA1Ba;AAAA;;AAAA;AAAA;AAAA,UA0BjDC,IA1BiD;AA2B3D,UAAIA,IAAI,CAACvD,MAAL,KAAgB,SAApB,EAA+B;AAC/B,UAAMqB,SAAS,GAAGkC,IAAI,CAAClC,SAAvB;AACAgC,MAAAA,cAAc,CAAChC,SAAD,CAAd,GAA4B,CAACkC,IAAI,CAACC,IAAL,IAAa,EAAd,EAAkBb,GAAlB,CAAsB,UAACP,IAAD;AAAA,eACjDD,SAAS,CAACC,IAAD,EAAOf,SAAP,EAAkBkC,IAAI,CAAClB,MAAvB,CADwC;AAAA,OAAtB,CAA5B;AA7B2D;;AA0B5D,2DAAmD;AAAA;;AAAA,+BACnB;AAK/B;AAhC2D;AAAA;AAAA;AAAA;AAAA;;AAkC5D,SAAO;AACNzB,IAAAA,IAAI,EAAJA,IADM;AAEN6C,IAAAA,IAAI,EAAE/C,MAFA;AAGNd,IAAAA,IAAI,EAAEa,KAHA;AAINwC,IAAAA,QAAQ,EAARA,QAJM;AAKNC,IAAAA,SAAS,EAATA,SALM;AAMNG,IAAAA,cAAc,EAAdA,cANM;AAONK,IAAAA,KAAK,EAAEhB,QAAQ,CAACgB,KAAT,IAAkB,EAPnB;AAQNC,IAAAA,kBAAkB,EAAEjB,QAAQ,CAACiB,kBAAT,IAA+B,EAR7C;AASNL,IAAAA,eAAe,EAAEZ,QAAQ,CAACY,eAAT,IAA4B,EATvC;AAUNM,IAAAA,UAAU,EAAElB,QAAQ,CAACkB,UAAT,IAAuB,EAV7B;AAWNC,IAAAA,MAAM,EAAEnB,QAAQ,CAACmB,MAAT,IAAmB,EAXrB;AAYNC,IAAAA,YAAY,EAAEpB,QAAQ,CAACoB,YAZjB;AAaNC,IAAAA,OAAO,EAAErB,QAAQ,CAACqB,OAAT,IAAoB,EAbvB;AAcNC,IAAAA,UAAU,EAAErB,GAAG,CAACsB,OAdV;AAeNC,IAAAA,UAAU,EAAExB,QAAQ,CAACwB;AAff,GAAP;AAiBA","sourcesContent":["function createNode(row, col, cols, previousNode) {\n\tconst node = previousNode || {};\n\tnode.id = row * cols + col;\n\tnode.row = row;\n\tnode.col = col;\n\tnode.status = node.status || \"unknown\";\n\tnode.backendState = node.backendState || \"UNKNOWN\";\n\tnode.distance = Infinity;\n\tnode.totalDistance = Infinity;\n\tnode.heuristicDistance = null;\n\tnode.direction = null;\n\tnode.weight = 0;\n\tnode.previousNode = null;\n\treturn node;\n}\n\nfunction createGrid(width, height, previousGrid = null) {\n\tconst grid = [];\n\tfor (let row = 0; row < height; row++) {\n\t\tconst currentRow = [];\n\t\tfor (let col = 0; col < width; col++) {\n\t\t\tconst previousNode = previousGrid && previousGrid[row] && previousGrid[row][col];\n\t\t\tcurrentRow.push(createNode(row, col, width, previousNode));\n\t\t}\n\t\tgrid.push(currentRow);\n\t}\n\treturn grid;\n}\n\nfunction mapCellStateToNodeStatus(state) {\n\tif (state === \"OBSTACLE\") return \"wall\";\n\tif (state === \"VISITED\") return \"visited\";\n\tif (state === \"FREE\") return \"default\";\n\tif (state === \"RESERVED\") return \"reserved\";\n\treturn \"unknown\";\n}\n\nfunction adaptVehicle(vehicle) {\n\tconst position = vehicle.pose && vehicle.pose.position ? vehicle.pose.position : {};\n\treturn {\n\t\tid: vehicle.vehicleId,\n\t\trow: Number(position.y || 0),\n\t\tcol: Number(position.x || 0),\n\t\theading: Number((vehicle.pose && vehicle.pose.heading) || 0),\n\t\tstatus: vehicle.status,\n\t\tbattery: vehicle.battery,\n\t\tcurrentTaskId: vehicle.currentTaskId,\n\t\tcurrentPlanId: vehicle.currentPlanId,\n\t\tcurrentStepIndex: vehicle.currentStepIndex || 0,\n\t};\n}\n\nfunction adaptFrontier(frontier) {\n\tconst position = frontier.position || {};\n\treturn {\n\t\tid: frontier.frontierId,\n\t\trow: Number(position.y || 0),\n\t\tcol: Number(position.x || 0),\n\t\tscore: frontier.score,\n\t\tunknownGain: frontier.unknownGain,\n\t\tstatus: frontier.status,\n\t};\n}\n\nfunction adaptStep(step, vehicleId, planId) {\n\tconst position = step.position || {};\n\treturn {\n\t\trow: Number(position.y || 0),\n\t\tcol: Number(position.x || 0),\n\t\tstepIndex: step.stepIndex,\n\t\texpectedTimeSlot: step.expectedTimeSlot,\n\t\theading: step.heading,\n\t\taction: step.action,\n\t\tvehicleId,\n\t\tplanId,\n\t};\n}\n\nexport function adaptSnapshot(snapshot, previousGrid = null) {\n\tconst map = snapshot.map || { width: 0, height: 0, cells: [] };\n\tconst width = Number(map.width || 0);\n\tconst height = Number(map.height || 0);\n\tconst grid = createGrid(width, height, previousGrid);\n\n\tfor (const cell of map.cells || []) {\n\t\tconst row = Number(cell.y);\n\t\tconst col = Number(cell.x);\n\t\tif (!grid[row] || !grid[row][col]) continue;\n\n\t\tconst node = grid[row][col];\n\t\tnode.backendState = cell.state;\n\t\tnode.status = mapCellStateToNodeStatus(cell.state);\n\t\tnode.confidence = cell.confidence;\n\t\tnode.updatedBy = cell.updatedBy;\n\t\tnode.updatedAt = cell.updatedAt;\n\t}\n\n\tconst vehicles = (snapshot.vehicles || []).map(adaptVehicle);\n\n\tconst frontiers = (snapshot.frontiers || [])\n\t\t.map(adaptFrontier)\n\t\t.filter((frontier) => [\"OPEN\", \"ASSIGNED\"].includes(frontier.status));\n\n\tconst pathsByVehicle = {};\n\tfor (const plan of snapshot.navigationPlans || []) {\n\t\tif (plan.status !== \"SUCCESS\") continue;\n\t\tconst vehicleId = plan.vehicleId;\n\t\tpathsByVehicle[vehicleId] = (plan.path || []).map((step) =>\n\t\t\tadaptStep(step, vehicleId, plan.planId)\n\t\t);\n\t}\n\n\treturn {\n\t\tgrid,\n\t\trows: height,\n\t\tcols: width,\n\t\tvehicles,\n\t\tfrontiers,\n\t\tpathsByVehicle,\n\t\ttasks: snapshot.tasks || [],\n\t\tnavigationRequests: snapshot.navigationRequests || [],\n\t\tnavigationPlans: snapshot.navigationPlans || [],\n\t\theartbeats: snapshot.heartbeats || [],\n\t\tevents: snapshot.events || [],\n\t\tsystemStatus: snapshot.systemStatus,\n\t\truntime: snapshot.runtime || {},\n\t\tmapVersion: map.version,\n\t\tsnapshotAt: snapshot.snapshotAt,\n\t};\n}\n"]}]}