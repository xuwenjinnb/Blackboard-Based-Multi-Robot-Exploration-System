A,EAAA;AACA,QAAA,OAAA,EAAA,OADA;AAEA,QAAA,IAAA,EAAA;AAFA,OATA;AAaA,MAAA,YAAA,EAAA;AACA,QAAA,OAAA,EAAA,MADA;AAEA,QAAA,IAAA;AAFA;AAbA,KAAA;AAAA,GALA;AAuCA,EAAA,QAAA,EAAA;AACA,IAAA,gBADA,8BACA;AACA,UAAA,OAAA,GAAA;AACA,QAAA,QAAA,EAAA,KAAA,MAAA,IAAA;AADA,OAAA;AAGA,MAAA,OAAA,CAAA,KAAA,MAAA,CAAA,GAAA,IAAA;AACA,aAAA,OAAA;AACA;AAPA,GAvCA;AAgDA,EAAA,OAhDA,qBAgDA;AACA,SAAA,OAAA,GAAA,KAAA,OAAA;AACA,GAlDA;AAmDA,EAAA,OAnDA,qBAmDA;AACA,SAAA,gBAAA;AACA,GArDA;AAsDA,EAAA,OAAA,EAAA;AACA,IAAA,gBADA,8BACA;AACA,WAAA,OAAA,CAAA,IAAA,yIAGA,KAAA,YAAA,CAAA,KAAA,MAAA,CAAA,KAAA,CAHA,mLASA,KAAA,YAAA,CAAA,KAAA,MAAA,CAAA,MAAA,CATA,mLAeA,KAAA,YAAA,CAAA,KAAA,MAAA,CAAA,OAAA,CAfA,qMAqBA,KAAA,YAAA,CAAA,KAAA,MAAA,CAAA,IAAA,CArBA;AA0BA,KA5BA;AA8BA,IAAA,YA9BA,wBA8BA,KA9BA,EA8BA;AACA,2BAAA,KAAA,CAAA,CAAA,GAAA,GAAA,eAAA,KAAA,CAAA,CAAA,GAAA,GAAA,eAAA,KAAA,CAAA,CAAA,GAAA,GAAA;AACA,KAhCA;AAkCA,IAAA,gBAlCA,8BAkCA;AAAA;;AACA,WAAA,OAAA,GAAA,KAAA,YAAA;AACA,WAAA,MAAA,GAAA,cAAA;AACA,UAAA,KAAA,aAAA,EAAA;AACA,WAAA,SAAA,CAAA,YAAA;AACA,QAAA,QAAA,CAAA,cAAA,CAAA,MAAA,EAAA,gBAAA,CAAA,OAAA,EAAA,KAAA,CAAA,SAAA;AACA,OAFA;AAGA,KAzCA;AA2CA,IAAA,SA3CA,uBA2CA;AAAA;;AACA,UAAA,KAAA,aAAA,EAAA;AAEA,MAAA,YAAA,CAAA,KAAA,WAAA,CAAA;AACA,WAAA,WAAA;;AACA,UAAA,KAAA,WAAA,IAAA,CAAA,EAAA;AACA,aAAA,KAAA,CAAA,aAAA;AACA,aAAA,aAAA,GAAA,IAAA;AACA;;AACA,WAAA,WAAA,GAAA,UAAA,CAAA,YAAA;AACA,QAAA,MAAA,CAAA,WAAA,GAAA,CAAA;AACA,OAFA,EAEA,IAFA,CAAA;AAGA,KAvDA;AAyDA,IAAA,cAzDA,4BAyDA;AACA,WAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,MAAA,CAAA,OAAA;AACA,UAAA,IAAA,GAAA,QAAA,CAAA,cAAA,CAAA,MAAA,CAAA;;AACA,UAAA,IAAA,EAAA;AACA,QAAA,IAAA,CAAA,mBAAA,CAAA,OAAA,EAAA,KAAA,SAAA;AACA;;AACA,WAAA,OAAA,GAAA,KAAA,OAAA;AACA,WAAA,MAAA,GAAA,EAAA;AACA,KAjEA;AAmEA,IAAA,KAnEA,iBAmEA,IAnEA,EAmEA;AAAA;;AACA,WAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,MAAA,CAAA,OAAA;AACA,WAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,GAAA,CAAA,OAAA;;AACA,UAAA,IAAA,EAAA;AACA,aAAA,OAAA,GAAA,IAAA;AACA;;AACA,MAAA,UAAA,CAAA,YAAA;AACA,QAAA,MAAA,CAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,MAAA,CAAA,OAAA;AACA,OAFA,EAEA,IAFA,CAAA;AAGA,KA5EA;AA8EA,IAAA,KA9EA,iBA8EA,IA9EA,EA8EA;AAAA;;AACA,WAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,MAAA,CAAA,OAAA;AACA,MAAA,UAAA,CAAA,YAAA;AACA,QAAA,MAAA,CAAA,KAAA,CAAA,OAAA,CAAA,SAAA,CAAA,GAAA,CAAA,OAAA;AACA,OAFA,EAEA,CAFA,CAAA;;AAGA,UAAA,IAAA,EAAA;AACA,aAAA,OAAA,GAAA,IAAA;AACA;AACA;AAtFA;AAtDA,CAAA","sourcesContent":["<template>\n\t<div class=\"info-container\" ref=\"infoBox\" :class=\"containerClasses\">\n\t\t<button class=\"btn-close\" @click=\"resetToLegends\" v-if=\"status != ''\">&#10006;</button>\n\t\t<h2>{{ current.heading }}</h2>\n\t\t<p class=\"main-content\" v-html=\"current.text\"></p>\n\t\t<div class=\"swarm-unlocked\" v-if=\"status == 'attributions' && swarmUnlocked\">群体算法已解锁</div>\n\t\t<div class=\"info-buttons\">\n\t\t\t<Button class=\"danger\" @click=\"showAttributions\" v-if=\"status == ''\">说明</Button>\n\t\t\t<a href=\"https://github.com/dhruvmisra/Pathfinding-Visualizer-ThreeJS\" target=\"_blank\">\n\t\t\t\t<Button class=\"white\" v-if=\"status == ''\">\n\t\t\t\t\t<img src=\"@/assets/icons/github-logo.svg\" alt=\"\" />\n\t\t\t\t</Button>\n\t\t\t</a>\n\t\t</div>\n\t\t<img class=\"info-icon\" src=\"@/assets/icons/info.svg\">\n\t</div>\n</template>\n\n<script>\nexport default {\n\tprops: {\n\t\tinfo: Object,\n\t\tcolors: Object\n\t},\n\tdata: () => ({\n\t\tstatus: '',\n\t\tcurrent: {\n\t\t\theading: \"\",\n\t\t\ttext: \"\"\n\t\t},\n\t\tclemCounter: 0,\n\t\tclemTimeout: null,\n\t\tswarmUnlocked: false,\n\t\tlegends: {\n\t\t\theading: \"寻路可视化\",\n\t\t\ttext: \"\"\n\t\t},\n\t\tattributions: {\n\t\t\theading: \"项目说明\",\n\t\t\ttext: `<div style=\"text-align: left\">\n\t\t\t\t<h3 style=\"margin: 5px 0; opacity: 0.4\">项目来源</h3>\n\t\t\t\t本界面基于 Pathfinding Visualizer ThreeJS 项目改造，用于三维展示网格寻路算法。<br>\n\t\t\t\t灵感来自 <span id=\"clem\">Clément Mihailescu</span> 的寻路可视化项目。\n\t\t\t\t<br><br>\n\t\t\t\t<h3 style=\"margin: 5px 0; opacity: 0.4\">WebGL 库</h3>\n\t\t\t\tThree.js\n\t\t\t\t<br><br>\n\t\t\t\t<h3 style=\"margin: 5px 0; opacity: 0.4\">资源与图标</h3>\n\t\t\t\t贴图来自 <a href=\"https://opengameart.org/\" target=\"_blank\">OpenGameArt.org</a><br>\n\t\t\t\t图标来自 <a href=\"https://www.flaticon.com/authors/freepik\" target=\"_blank\">Freepik</a> / <a href=\"https://www.flaticon.com/\" target=\"_blank\">Flaticon</a>\n\t\t\t\t<br><br>\n\t\t\t\t<h3 style=\"margin: 5px 0; opacity: 0.4\">源代码</h3>\n\t\t\t\t原项目仓库：<a href=\"https://github.com/dhruvmisra/Pathfinding-Visualizer-ThreeJS\" target=\"_blank\">Pathfinding-Visualizer-ThreeJS</a>.\n\t\t\t\t<br><br>\n\t\t\t\t<p style=\"text-align: center; margin: 1em 0;\">使用 Vue.js 和 Three.js 构建</p>\n\t\t\t</div>`\n\t\t}\n\t}),\n\tcomputed: {\n\t\tcontainerClasses() {\n\t\t\tlet classes = {\n\t\t\t\tcentered: this.status == 'attributions'\n\t\t\t}\n\t\t\tclasses[this.status] = true;\n\t\t\treturn classes;\n\t\t}\n\t},\n\tcreated() {\n\t\tthis.current = this.legends;\n\t},\n\tmounted() {\n\t\tthis.constructLegends();\n\t},\n\tmethods: {\n\t\tconstructLegends() {\n\t\t\tthis.legends.text += `<table class=\"legends-table\">\n\t\t\t\t<tr>\n\t\t\t\t\t<td>\n\t\t\t\t\t\t<div class=\"square\" style=\"background-color: ${this.getRGBString(this.colors.start)}\"></div>\n\t\t\t\t\t</td>\n\t\t\t\t\t<td>起点</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<td>\n\t\t\t\t\t\t<div class=\"square\" style=\"background-color: ${this.getRGBString(this.colors.finish)}\"></div>\n\t\t\t\t\t</td>\n\t\t\t\t\t<td>终点</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<td>\n\t\t\t\t\t\t<div class=\"square\" style=\"background-color: ${this.getRGBString(this.colors.visited)}\"></div>\n\t\t\t\t\t</td>\n\t\t\t\t\t<td>已访问节点</td>\n\t\t\t\t</tr>\n\t\t\t\t<tr>\n\t\t\t\t\t<td>\n\t\t\t\t\t\t<div class=\"square\" style=\"background-color: ${this.getRGBString(this.colors.path)}\"></div>\n\t\t\t\t\t</td>\n\t\t\t\t\t<td>路径节点</td>\n\t\t\t\t</tr>\n\t\t\t</table>`\n\t\t},\n\n\t\tgetRGBString(color) {\n\t\t\treturn `rgb(${color.r*255}, ${color.g*255}, ${color.b*255})`;\n\t\t},\n\n\t\tshowAttributions() {\n\t\t\tthis.current = this.attributions;\n\t\t\tthis.status = 'attributions';\n\t\t\tif(this.swarmUnlocked) return;\n\t\t\tthis.$nextTick(() => {\n\t\t\t\tdocument.getElementById('clem').addEventListener('click', this.clemClick);\n\t\t\t});\n\t\t},\n\n\t\tclemClick() {\n\t\t\tif(this.swarmUnlocked) return;\n\n\t\t\tclearTimeout(this.clemTimeout);\n\t\t\tthis.clemCounter++;\n\t\t\tif(this.clemCounter == 5) {\n\t\t\t\tthis.$emit('unlockSwarm');\n\t\t\t\tthis.swarmUnlocked = true;\n\t\t\t}\n\t\t\tthis.clemTimeout = setTimeout(() => {\n\t\t\t\tthis.clemCounter = 0;\n\t\t\t}, 3000);\n\t\t},\n\n\t\tresetToLegends() {\n\t\t\tthis.$refs.infoBox.classList.remove('error');\n\t\t\tlet clem = document.getElementById('clem');\n\t\t\tif(clem) {\n\t\t\t\tclem.removeEventListener('click', this.clemClick);\n\t\t\t}\n\t\t\tthis.current = this.legends;\n\t\t\tthis.status = '';\n\t\t},\n\n\t\talert(info) {\n\t\t\tthis.$refs.infoBox.classList.remove('error');\n\t\t\tthis.$refs.infoBox.classList.add('alert');\n\t\t\tif(info) {\n\t\t\t\tthis.current = info;\n\t\t\t}\n\t\t\tsetTimeout(() => {\n\t\t\t\tthis.$refs.infoBox.classList.remove('alert');\n\t\t\t}, 1000);\n\t\t},\n\n\t\terror(info) {\n\t\t\tthis.$refs.infoBox.classList.remove('error');\n\t\t\tsetTimeout(() => {\n\t\t\t\tthis.$refs.infoBox.classList.add('error');\n\t\t\t}, 0)\n\t\t\tif(info) {\n\t\t\t\tthis.current = info;\n\t\t\t}\n\t\t}\n\t}\n}\n</script>\n\n<style lang=\"scss\">\n@import '@/scss/variables.scss';\n\n.info-container {\n\tposition: absolute;\n\tright: 15px;\n\tbottom: 15px;\n\twidth: 350px;\n\tmax-height: 100%;\n\tmax-width: 90%;\n\tdisplay: flex;\n\tflex-direction: column;\n\tfont-size: 0.9em;\n\tpadding: 25px;\n\tborder-radius: 5px;\n\tbackground: linear-gradient(0, $dark 0%, #000000 240%);\n\tcolor: white;\n\tbox-shadow: 2px 10px 30px rgba(#000, 0.4);\n\topacity: 0.4;\n\tz-index: 10000;\n\tclip-path: circle(30px at calc(100% - 30px) calc(100% - 30px));\n\ttransition: all 400ms ease-in-out;\n\n\t&:hover {\n\t\tclip-path: circle(200% at calc(100% - 30px) calc(100% - 30px));\n\t\topacity: 1;\n\t\tbottom: 20px;\n\t}\n\n\t&.centered {\n\t\tmax-height: 90%;\n\t\tmin-height: 50%;\n\t\twidth: 600px;\n\t\tmax-width: 95%;\n\t\topacity: 1;\n\t\tfont-size: 1em;\n\t\ttext-align: center;\n\t\tright: 50%;\n\t\tbottom: 50%;\n\t\ttransform: translate(50%, 50%);\n\t\tclip-path: circle(200% at calc(100% - 30px) calc(100% - 30px));\n\t}\n\n\t&.alert {\n\t\tanimation: alert 1000ms ease-in-out;\n\t}\n\t@keyframes alert {\n\t\t0%, 100% {\n\t\t\tbottom: 15px;\n\t\t\topacity: 0.4;\n\t\t}\n\t\t20%, 50% {\n\t\t\tbottom: 30px;\n\t\t\topacity: 1;\n\t\t}\n\t\t40% {\n\t\t\tbottom: 25px;\n\t\t\topacity: 1;\n\t\t}\n\t}\n\n\t&.error {\n\t\tbackground: linear-gradient(0, brown 0%, #000000 240%);\n\t\tanimation: error 400ms ease-out;\n\t}\n\t@keyframes error {\n\t\t0%, 100% {\n\t\t\tright: 15px;\n\t\t\topacity: 0.4;\n\t\t}\n\t\t20%, 60% {\n\t\t\tright: 25px;\n\t\t\topacity: 1;\n\t\t}\n\t\t40%, 80% {\n\t\t\tright: 5px;\n\t\t\topacity: 1;\n\t\t}\n\t}\n\n\t.main-content {\n\t\topacity: 0.9;\n\t\tmargin-bottom: 3em;\n\t\toverflow: auto;\n\t}\n\t&.attributions {\n\t\t.main-content {\n\t\t\tmargin-bottom: 0;\n\t\t}\n\t\t#clem {\n\t\t\tcursor: pointer;\n\t\t\tuser-select: none;\n\t\t\t-moz-user-select: none;\n\t\t\t-webkit-user-select: none;\n\t\t}\n\t\t.swarm-unlocked {\n\t\t\twidth: fit-content;\n\t\t\tmargin: 0 auto;\n\t\t\tpadding: 5px;\n\t\t\tfont-size: 0.8em;\n\t\t\tborder-radius: 5px;\n\t\t\tcolor: #0f0;\n\t\t\tbackground: rgba(#0f0, 0.3);\n\t\t}\n\t}\n\n\th2 {\n\t\tmargin: 0.5em 0;\n\t}\n\n\t.btn-close {\n\t\tposition: absolute;\n\t\ttop: 10px;\n\t\tright: 10px;\n\t\theight: 30px;\n\t\twidth: 30px;\n\t\tborder: none;\n\t\tborder-radius: 50%;\n\t\tbackground: transparent;\n\t\tcolor: white;\n\t\tcursor: pointer;\n\t\ttransition: background 200ms ease-out;\n\t\t&:hover {\n\t\t\tbackground: rgba(255, 255, 255, 0.1);\n\t\t}\n\t\t&:focus {\n\t\t\toutline: none;\n\t\t}\n\t}\n\n\ta {\n\t\tcolor: rgb(255, 124, 124);\n\t}\n\n\timg {\n\t\tborder-radius: 5px;\n\t}\n\n\ttable {\n\t\tborder-spacing: 0;\n\t\tfont-size: 0.9em;\n\n\t\t&.camera-table {\n\t\t\tmargin: 0 auto;\n\n\t\t\ttd {\n\t\t\t\twidth: 50%;\n\t\t\t\tborder: solid 1px white;\n\t\t\t\tpadding: 10px;\n\t\t\t}\n\t\t}\n\t\t&.legends-table {\n\t\t\ttd {\n\t\t\t\tpadding: 5px;\n\n\t\t\t\t.square {\n\t\t\t\t\twidth: 30px;\n\t\t\t\t\theight: 30px;\n\t\t\t\t\tmargin: 0 auto;\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t}\n\n\t.info-buttons {\n\t\tdisplay: flex;\n\t\tflex-wrap: wrap;\n\t\talign-items: center;\n\t\tmargin-top: auto;\n\n\t\t.tutorial-buttons {\n\t\t\tdisplay: flex;\n\t\t\tflex-wrap: wrap;\n\t\t\talign-items: center;\n\t\t\twidth: 95%;\n\t\t}\n\n\t\t.btn-group {\n\t\t\tdisplay: flex;\n\t\t\tmargin: 0 auto;\n\t\t}\n\t\t.btn-tutorial {\n\t\t\tpadding: 0 1em;\n\t\t}\n\t}\n\n\t.info-icon {\n\t\tposition: absolute;\n\t\tright: 10px;\n\t\tbottom: 10px;\n\t\theight: 40px;\n\t}\n}\n</style>\n"],"sourceRoot":"src/components/UI"}]}